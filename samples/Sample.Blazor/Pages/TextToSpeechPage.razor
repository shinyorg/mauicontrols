@page "/texttospeech"

<PageTitle>Text to Speech</PageTitle>

<h1>Text to Speech Button</h1>

<section class="demo-section">
    <h2>Custom text</h2>
    <input type="text" @bind="customText" placeholder="Type something to speak..." style="width:100%;max-width:400px;padding:8px;margin-bottom:12px;" />
    <div class="row">
        <TextToSpeechButton Text="Speak"
                            SpeechText="@customText"
                            ButtonBackgroundColor="#2196F3" />
    </div>
</section>

<section class="demo-section">
    <h2>Basic</h2>
    <div class="row">
        <TextToSpeechButton Text="Hello World"
                            SpeechText="Hello World! Welcome to Shiny Controls."
                            ButtonBackgroundColor="#4CAF50" />
        <TextToSpeechButton Text="Play"
                            Icon="<svg viewBox='0 0 24 24' fill='currentColor'><path d='M8 5v14l11-7z'/></svg>"
                            SpeechText="This button has an icon and text."
                            ButtonBackgroundColor="#9C27B0" />
    </div>
</section>

<section class="demo-section">
    <h2>Styled</h2>
    <div class="row">
        <TextToSpeechButton Text="Outlined"
                            SpeechText="This is an outlined text to speech button."
                            ButtonBackgroundColor="transparent"
                            BorderColor="#E91E63"
                            BorderThickness="2"
                            TextColor="#E91E63"
                            CornerRadius="20" />
        <TextToSpeechButton Text="Shadow"
                            SpeechText="This button has a shadow."
                            ButtonBackgroundColor="#FF9800"
                            HasShadow="true" />
    </div>
</section>

<section class="demo-section">
    <h2>Speech options</h2>
    <div style="margin-bottom:12px;">
        <label>Pitch: @pitch.ToString("F1")</label>
        <input type="range" min="0.5" max="2.0" step="0.1" @bind="pitch" style="width:200px;" />
    </div>
    <div style="margin-bottom:12px;">
        <label>Volume: @volume.ToString("F1")</label>
        <input type="range" min="0" max="1.0" step="0.1" @bind="volume" style="width:200px;" />
    </div>
    <div style="margin-bottom:12px;">
        <label>Rate: @rate.ToString("F1")</label>
        <input type="range" min="0.5" max="2.0" step="0.1" @bind="rate" style="width:200px;" />
    </div>
    <TextToSpeechButton Text="Speak with options"
                        SpeechText="You can control the pitch, volume, and rate of the speech."
                        Pitch="@pitch"
                        Volume="@volume"
                        Rate="@rate"
                        ButtonBackgroundColor="#FF9800" />
</section>

<section class="demo-section">
    <h2>Speaking state</h2>
    <TextToSpeechButton Text="@(isSpeaking ? "Stop" : "Listen")"
                        SpeechText="This is a longer sentence so you have time to see the speaking state change. The button text changes while speaking."
                        @bind-IsSpeaking="isSpeaking"
                        ButtonBackgroundColor="@(isSpeaking ? "#F44336" : "#2196F3")" />
    <p>IsSpeaking: <strong>@isSpeaking</strong></p>
</section>

@code {
    string customText = "Hello from Shiny Controls!";
    float pitch = 1.0f;
    float volume = 1.0f;
    float rate = 1.0f;
    bool isSpeaking;
}
