<?xml version="1.0" encoding="UTF-8" ?>
<shiny:ShinyShell
    x:Class="Sample.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:shiny="clr-namespace:Shiny;assembly=Shiny.Maui.Shell"
    xmlns:local="clr-namespace:Sample"
    xmlns:pages="clr-namespace:Sample.Pages"
    Title="Sample">

    <FlyoutItem Title="Bottom Sheet">
        <ShellContent ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" />
    </FlyoutItem>

    <FlyoutItem Title="Pills">
        <ShellContent ContentTemplate="{DataTemplate local:PillPage}" Route="PillPage" />
    </FlyoutItem>

    <FlyoutItem Title="TableView - Basic Settings">
        <ShellContent ContentTemplate="{DataTemplate pages:BasicSettingsPage}" Route="basic" />
    </FlyoutItem>

    <FlyoutItem Title="TableView - Dynamic Sections">
        <ShellContent ContentTemplate="{DataTemplate pages:DynamicSectionsPage}" Route="dynamic" />
    </FlyoutItem>

    <FlyoutItem Title="TableView - Drag &amp; Sort">
        <ShellContent ContentTemplate="{DataTemplate pages:DragSortPage}" Route="dragsort" />
    </FlyoutItem>

    <FlyoutItem Title="TableView - Picker Demo">
        <ShellContent ContentTemplate="{DataTemplate pages:PickerDemoPage}" Route="picker" />
    </FlyoutItem>

    <FlyoutItem Title="TableView - Styling">
        <ShellContent ContentTemplate="{DataTemplate pages:StylingPage}" Route="styling" />
    </FlyoutItem>

    <FlyoutItem Title="Scheduler - Calendar">
        <ShellContent ContentTemplate="{DataTemplate pages:CalendarPage}" Route="calendar" />
    </FlyoutItem>

    <FlyoutItem Title="Scheduler - Agenda">
        <ShellContent ContentTemplate="{DataTemplate pages:AgendaPage}" Route="agenda" />
    </FlyoutItem>

    <FlyoutItem Title="Scheduler - Event List">
        <ShellContent ContentTemplate="{DataTemplate pages:CalendarListPage}" Route="calendarlist" />
    </FlyoutItem>

    <FlyoutItem Title="Diagrams - Basic Flowchart">
        <ShellContent ContentTemplate="{DataTemplate pages:BasicFlowchartPage}" Route="flowchart" />
    </FlyoutItem>

    <FlyoutItem Title="Diagrams - Directions">
        <ShellContent ContentTemplate="{DataTemplate pages:DirectionsPage}" Route="directions" />
    </FlyoutItem>

    <FlyoutItem Title="Diagrams - Themes">
        <ShellContent ContentTemplate="{DataTemplate pages:ThemesPage}" Route="themes" />
    </FlyoutItem>

    <FlyoutItem Title="Diagrams - Subgraphs">
        <ShellContent ContentTemplate="{DataTemplate pages:SubgraphsPage}" Route="subgraphs" />
    </FlyoutItem>

    <FlyoutItem Title="Diagrams - Editor">
        <ShellContent ContentTemplate="{DataTemplate pages:InteractiveEditorPage}" Route="editor" />
    </FlyoutItem>

</shiny:ShinyShell>
