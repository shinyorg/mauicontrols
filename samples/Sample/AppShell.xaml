<?xml version="1.0" encoding="UTF-8" ?>
<shiny:ShinyShell
    x:Class="Sample.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:shiny="clr-namespace:Shiny;assembly=Shiny.Maui.Shell"
    xmlns:home="clr-namespace:Sample.Features.Home"
    xmlns:fp="clr-namespace:Sample.Features.FloatingPanel"
    xmlns:pills="clr-namespace:Sample.Features.Pills"
    xmlns:tv="clr-namespace:Sample.Features.TableView"
    xmlns:scheduler="clr-namespace:Sample.Features.Scheduler"
    xmlns:diagrams="clr-namespace:Sample.Features.Diagrams"
    xmlns:imgviewer="clr-namespace:Sample.Features.ImageViewer"
    xmlns:imgeditor="clr-namespace:Sample.Features.ImageEditor"
    xmlns:chat="clr-namespace:Sample.Features.Chat"
    xmlns:kitchensink="clr-namespace:Sample.Features.KitchenSink"
    xmlns:markdown="clr-namespace:Sample.Features.Markdown"
    xmlns:securitypin="clr-namespace:Sample.Features.SecurityPin"
    xmlns:fab="clr-namespace:Sample.Features.Fab"
    xmlns:colorpicker="clr-namespace:Sample.Features.ColorPicker"
    xmlns:autocomplete="clr-namespace:Sample.Features.AutoComplete"
    xmlns:countryaddress="clr-namespace:Sample.Features.CountryAddress"
    xmlns:sigpad="clr-namespace:Sample.Features.SignaturePad"
    Title="Shiny Controls"
    FlyoutBackgroundColor="{AppThemeBinding Light=#F5F3FF, Dark=#0F0D1A}"
    FlyoutWidth="310"
    Shell.BackgroundColor="{AppThemeBinding Light=#7C3AED, Dark=#2D1B69}"
    Shell.ForegroundColor="White"
    Shell.TitleColor="White"
    Shell.UnselectedColor="#C4B5FD"
    FlyoutHeaderBehavior="CollapseOnScroll">

    <!-- ============================================================ -->
    <!-- FLYOUT HEADER — Logo + gradient hero -->
    <!-- ============================================================ -->
    <Shell.FlyoutHeader>
        <Grid HeightRequest="200">
            <!-- Gradient background -->
            <BoxView>
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C3AED" Offset="0.0" />
                        <GradientStop Color="#4F46E5" Offset="0.5" />
                        <GradientStop Color="#2563EB" Offset="1.0" />
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>

            <!-- Decorative circles for depth -->
            <BoxView CornerRadius="80"
                     WidthRequest="160" HeightRequest="160"
                     Color="#FFFFFF" Opacity="0.06"
                     HorizontalOptions="End" VerticalOptions="Start"
                     Margin="0,-30,-40,0" />
            <BoxView CornerRadius="50"
                     WidthRequest="100" HeightRequest="100"
                     Color="#FFFFFF" Opacity="0.04"
                     HorizontalOptions="Start" VerticalOptions="End"
                     Margin="-20,0,0,-20" />

            <!-- Logo + text -->
            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="8"
                                 Padding="24,52,24,24">
                <!-- Logo with glow shadow -->
                <Border StrokeThickness="0"
                        BackgroundColor="Transparent"
                        HorizontalOptions="Center"
                        WidthRequest="72" HeightRequest="72">
                    <Border.Shadow>
                        <Shadow Brush="#8B5CF6"
                                Offset="0,4"
                                Radius="20"
                                Opacity="0.6" />
                    </Border.Shadow>
                    <Image Source="shiny_logo.png"
                           HeightRequest="72"
                           WidthRequest="72" />
                </Border>

                <Label Text="Shiny Controls"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center">
                    <Label.Shadow>
                        <Shadow Brush="#000000"
                                Offset="0,2"
                                Radius="8"
                                Opacity="0.3" />
                    </Label.Shadow>
                </Label>

                <Border BackgroundColor="#FFFFFF"
                        Opacity="0.2"
                        StrokeThickness="0"
                        HeightRequest="2"
                        WidthRequest="60"
                        HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="1" />
                    </Border.StrokeShape>
                </Border>

                <Label Text="MAUI &amp; Blazor Component Gallery"
                       FontSize="11"
                       TextColor="#DDD6FE"
                       HorizontalTextAlignment="Center"
                       CharacterSpacing="0.5" />
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <!-- ============================================================ -->
    <!-- ITEM TEMPLATE — Icon + Title with accent styling -->
    <!-- ============================================================ -->
    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid Padding="8,2" HeightRequest="42">
                <Border Padding="10,6"
                        StrokeThickness="0"
                        BackgroundColor="Transparent">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="28,*" ColumnSpacing="10">
                        <Image Source="{Binding FlyoutIcon}"
                               HeightRequest="18" WidthRequest="18"
                               VerticalOptions="Center"
                               HorizontalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding Title}"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light=#1E1B4B, Dark=#E0E7FF}"
                               VerticalTextAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <!-- ============================================================ -->
    <!-- SECTION HEADER TEMPLATE — Category labels -->
    <!-- ============================================================ -->
    <Shell.MenuItemTemplate>
        <DataTemplate>
            <Grid Padding="20,14,20,4" HeightRequest="36">
                <Label Text="{Binding Text}"
                       FontSize="11"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#7C3AED, Dark=#6D28D9}"
                       VerticalTextAlignment="End"
                       CharacterSpacing="1.5" />
            </Grid>
        </DataTemplate>
    </Shell.MenuItemTemplate>

    <!-- ============================================================ -->
    <!-- FLYOUT FOOTER — Branding -->
    <!-- ============================================================ -->
    <Shell.FlyoutFooter>
        <Grid Padding="16,8,16,12" RowDefinitions="Auto,Auto" RowSpacing="4"
              BackgroundColor="{AppThemeBinding Light=#F5F3FF, Dark=#0F0D1A}">
            <!-- Accent line -->
            <BoxView HeightRequest="1" Margin="20,0,20,2">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="Transparent" Offset="0.0" />
                        <GradientStop Color="{AppThemeBinding Light=#7C3AED, Dark=#6D28D9}" Offset="0.5" />
                        <GradientStop Color="Transparent" Offset="1.0" />
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>

            <!-- Tappable badge — opens shinylib.net -->
            <Border x:Name="footerBadge"
                    Grid.Row="1"
                    BackgroundColor="{AppThemeBinding Light=#EDE9FE, Dark=#1E1B4B}"
                    StrokeThickness="0"
                    Padding="12,6"
                    HorizontalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFooterTapped" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
                    <Label Text="shinylib.net"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#6D28D9, Dark=#A78BFA}"
                           VerticalTextAlignment="Center"
                           TextDecorations="Underline" />
                    <BoxView WidthRequest="3" HeightRequest="3" CornerRadius="2"
                             Color="{AppThemeBinding Light=#6D28D9, Dark=#A78BFA}"
                             VerticalOptions="Center" />
                    <Label Text=".NET MAUI &amp; Blazor"
                           FontSize="11"
                           TextColor="{AppThemeBinding Light=#7C3AED, Dark=#8B5CF6}"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>
            </Border>
        </Grid>
    </Shell.FlyoutFooter>

    <!-- ============================================================ -->
    <!--  HOME -->
    <!-- ============================================================ -->
    <FlyoutItem Title="Home">
        <FlyoutItem.FlyoutIcon>
            <FontImageSource Glyph="&#x2302;" Size="20"
                             Color="{AppThemeBinding Light=#7C3AED, Dark=#A78BFA}" />
        </FlyoutItem.FlyoutIcon>
        <ShellContent ContentTemplate="{DataTemplate home:HomePage}" Route="home" />
