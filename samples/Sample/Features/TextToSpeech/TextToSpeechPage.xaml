<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shiny="http://shiny.net/maui/controls"
             xmlns:local="clr-namespace:Sample.Features.TextToSpeech"
             x:Class="Sample.Features.TextToSpeech.TextToSpeechPage"
             x:DataType="local:TextToSpeechViewModel"
             Title="Text to Speech">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <Label Text="Text to Speech Button"
                   FontSize="22"
                   FontAttributes="Bold" />

            <Label Text="{Binding StatusMessage}"
                   FontSize="14"
                   TextColor="Gray" />

            <BoxView HeightRequest="1" Color="LightGray" />

            <Label Text="Custom speech text" FontAttributes="Bold" />
            <Entry Text="{Binding CustomText}"
                   Placeholder="Type something to speak..." />

            <shiny:TextToSpeechButton Text="Speak"
                                      SpeechText="{Binding CustomText}"
                                      ButtonBackgroundColor="#2196F3"
                                      TextColor="White"
                                      HorizontalOptions="Start" />

            <BoxView HeightRequest="1" Color="LightGray" />

            <Label Text="Basic (text only)" FontAttributes="Bold" />
            <shiny:TextToSpeechButton Text="Hello World"
                                      SpeechText="Hello World! Welcome to Shiny Controls."
                                      ButtonBackgroundColor="#4CAF50"
                                      TextColor="White"
                                      HorizontalOptions="Start" />

            <Label Text="With icon" FontAttributes="Bold" />
            <shiny:TextToSpeechButton Text="Play"
                                      Icon="dotnet_bot.png"
                                      SpeechText="This button has an icon and text."
                                      ButtonBackgroundColor="#9C27B0"
                                      TextColor="White"
                                      HorizontalOptions="Start" />

            <Label Text="Styled (outlined)" FontAttributes="Bold" />
            <shiny:TextToSpeechButton Text="Outlined"
                                      SpeechText="This is an outlined text to speech button."
                                      ButtonBackgroundColor="Transparent"
                                      BorderColor="#E91E63"
                                      BorderThickness="2"
                                      TextColor="#E91E63"
                                      CornerRadius="20"
                                      HorizontalOptions="Start" />

            <BoxView HeightRequest="1" Color="LightGray" />

            <Label Text="Speech options" FontAttributes="Bold" />

            <HorizontalStackLayout Spacing="10">
                <Label Text="Pitch:" VerticalTextAlignment="Center" />
                <Slider Minimum="0.5" Maximum="2.0"
                        Value="{Binding Pitch}"
                        WidthRequest="200" />
                <Label Text="{Binding Pitch, StringFormat='{0:F1}'}"
                       VerticalTextAlignment="Center" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <Label Text="Volume:" VerticalTextAlignment="Center" />
                <Slider Minimum="0" Maximum="1.0"
                        Value="{Binding Volume}"
                        WidthRequest="200" />
                <Label Text="{Binding Volume, StringFormat='{0:F1}'}"
                       VerticalTextAlignment="Center" />
            </HorizontalStackLayout>

            <shiny:TextToSpeechButton Text="Speak with options"
                                      SpeechText="You can control the pitch and volume of the speech."
                                      Pitch="{Binding Pitch}"
                                      Volume="{Binding Volume}"
                                      ButtonBackgroundColor="#FF9800"
                                      TextColor="White"
                                      HasShadow="True"
                                      HorizontalOptions="Start" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
