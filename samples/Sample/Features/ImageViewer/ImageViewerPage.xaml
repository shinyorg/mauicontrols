<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shiny="http://shiny.net/maui/controls"
             xmlns:local="clr-namespace:Sample.Features.ImageViewer"
             x:Class="Sample.Features.ImageViewer.ImageViewerPage"
             x:DataType="local:ImageViewerViewModel"
             Title="Image Viewer">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="16">
                <Label Text="Tap an image to open the viewer"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center" />

                <Label Text="Pinch to zoom, pan when zoomed, double-tap to toggle zoom, X to close."
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       TextColor="Gray" />

                <Image Source="dotnet_bot.png"
                       HeightRequest="200"
                       Aspect="AspectFit">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenViewerCommand}"
                                              CommandParameter="dotnet_bot.png" />
                    </Image.GestureRecognizers>
                </Image>
            </VerticalStackLayout>
        </ScrollView>

        <shiny:ImageViewer Source="{Binding SelectedImage}"
                           IsOpen="{Binding IsViewerOpen}" />
    </Grid>

</ContentPage>
