<?xml version="1.0" encoding="utf-8" ?>
<shiny:ShinyContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shiny="http://shiny.net/maui/controls"
             xmlns:local="clr-namespace:Sample.Features.ImageViewer"
             x:Class="Sample.Features.ImageViewer.ImageViewerPage"
             x:DataType="local:ImageViewerViewModel"
             Title="Image Viewer">

    <shiny:ShinyContentPage.PageContent>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="16">
                <Label Text="Tap an image to open the viewer"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center" />

                <Label Text="Pinch to zoom, pan when zoomed, double-tap to toggle zoom, X to close."
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       TextColor="Gray" />

                <shiny:ImageViewer Source="dotnet_bot.png"
                                   IsOpen="{Binding IsViewerOpen}"
                                   HeightRequest="200"
                                   Aspect="AspectFit">
                    <shiny:ImageViewer.FooterTemplate>
                        <DataTemplate x:DataType="local:ImageViewerViewModel">
                            <Button Text="Close"
                                    Command="{Binding CloseViewerCommand}"
                                    TextColor="White"
                                    BackgroundColor="{x:Static Colors.DimGray}"
                                    CornerRadius="20"
                                    HorizontalOptions="Center"
                                    Margin="0,0,0,40" />
                        </DataTemplate>
                    </shiny:ImageViewer.FooterTemplate>
                </shiny:ImageViewer>
            </VerticalStackLayout>
        </ScrollView>
    </shiny:ShinyContentPage.PageContent>

</shiny:ShinyContentPage>
