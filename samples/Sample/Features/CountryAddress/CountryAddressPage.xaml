<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Sample.Features.CountryAddress"
             xmlns:shiny="http://shiny.net/maui/controls"
             x:Class="Sample.Features.CountryAddress.CountryAddressPage"
             x:DataType="local:CountryAddressViewModel"
             Title="Country &amp; Address"
             BackgroundColor="#F5F7FA">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Header -->
            <VerticalStackLayout Spacing="4" Padding="0,8,0,4">
                <Label Text="&#x1F30E; Location"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#1E293B"
                       HorizontalTextAlignment="Center" />
                <Label Text="Pick a country and search for an address"
                       FontSize="13"
                       TextColor="#64748B"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Country Picker Card -->
            <Border StrokeShape="{RoundRectangle CornerRadius=16}"
                    Stroke="#E2E8F0" StrokeThickness="1"
                    BackgroundColor="White" Padding="20">
                <VerticalStackLayout Spacing="14">
                    <HorizontalStackLayout Spacing="8">
                        <Border StrokeShape="{RoundRectangle CornerRadius=8}"
                                Stroke="Transparent" BackgroundColor="#EEF2FF"
                                Padding="8,6" VerticalOptions="Center">
                            <Label Text="&#x1F3F3;&#xFE0F;" FontSize="16" />
                        </Border>
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="Country"
                                   FontSize="17" FontAttributes="Bold" TextColor="#1E293B" />
                            <Label Text="Search from 250+ countries"
                                   FontSize="11" TextColor="#94A3B8" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <shiny:CountryPicker
                        SelectedCountry="{Binding SelectedCountry}"
                        Placeholder="Search countries..."
                        FontSize="15"
                        CornerRadius="10"
                        DropDownBackgroundColor="White"
                        DropDownBorderColor="#CBD5E1" />

                    <!-- Country Details -->
                    <Border StrokeShape="{RoundRectangle CornerRadius=10}"
                            Stroke="#E0E7FF" StrokeThickness="1"
                            BackgroundColor="#F5F3FF" Padding="14"
                            IsVisible="{Binding HasCountry}">
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto"
                              ColumnSpacing="14" RowSpacing="8">

                            <Label Text="&#x1F3F7;&#xFE0F;" FontSize="14" VerticalTextAlignment="Center" />
                            <HorizontalStackLayout Grid.Column="1" Spacing="6">
                                <Label Text="{Binding SelectedCountry.FlagEmoji}" FontSize="20" VerticalTextAlignment="Center" />
                                <Label Text="{Binding SelectedCountry.Name}" FontSize="14" FontAttributes="Bold" TextColor="#1E293B" VerticalTextAlignment="Center" />
                            </HorizontalStackLayout>

                            <Label Grid.Row="1" Text="&#x1F4C7;" FontSize="14" VerticalTextAlignment="Center" />
                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding CountryCodeDisplay}" FontSize="13" TextColor="#475569" VerticalTextAlignment="Center" />

                            <Label Grid.Row="2" Text="&#x260E;&#xFE0F;" FontSize="14" VerticalTextAlignment="Center" />
                            <Label Grid.Row="2" Grid.Column="1"
                                   Text="{Binding SelectedCountry.DialCode}" FontSize="13" TextColor="#475569" VerticalTextAlignment="Center" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Address Entry Card -->
            <Border StrokeShape="{RoundRectangle CornerRadius=16}"
                    Stroke="#E2E8F0" StrokeThickness="1"
                    BackgroundColor="White" Padding="20">
                <VerticalStackLayout Spacing="14">
                    <HorizontalStackLayout Spacing="8">
                        <Border StrokeShape="{RoundRectangle CornerRadius=8}"
                                Stroke="Transparent" BackgroundColor="#ECFDF5"
                                Padding="8,6" VerticalOptions="Center">
                            <Label Text="&#x1F4CD;" FontSize="16" />
                        </Border>
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="Address"
                                   FontSize="17" FontAttributes="Bold" TextColor="#1E293B" />
                            <Label Text="OpenStreetMap Nominatim (free, no API key)"
                                   FontSize="11" TextColor="#94A3B8" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <shiny:AddressEntry
                        SelectedAddress="{Binding SelectedAddress}"
                        CountryCodes="{Binding CountryCodeFilter}"
                        Placeholder="Start typing an address..."
                        FontSize="15"
                        CornerRadius="10"
                        DropDownBackgroundColor="White"
                        DropDownBorderColor="#CBD5E1"
                        SpinnerColor="#10B981" />

                    <!-- Address Details -->
                    <Border StrokeShape="{RoundRectangle CornerRadius=10}"
                            Stroke="#D1FAE5" StrokeThickness="1"
                            BackgroundColor="#ECFDF5" Padding="14"
                            IsVisible="{Binding HasAddress}">
                        <Grid ColumnDefinitions="Auto,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                              ColumnSpacing="14" RowSpacing="8">

                            <Label Text="&#x1F3E0;" FontSize="14" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding StreetDisplay}"
                                   FontSize="13" TextColor="#1E293B" FontAttributes="Bold" VerticalTextAlignment="Center" />

                            <Label Grid.Row="1" Text="&#x1F3D9;&#xFE0F;" FontSize="14" VerticalTextAlignment="Center" />
                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding SelectedAddress.City}" FontSize="13" TextColor="#475569" VerticalTextAlignment="Center" />

                            <Label Grid.Row="2" Text="&#x1F3DB;&#xFE0F;" FontSize="14" VerticalTextAlignment="Center" />
                            <HorizontalStackLayout Grid.Row="2" Grid.Column="1" Spacing="8">
                                <Label Text="{Binding SelectedAddress.State}" FontSize="13" TextColor="#475569" VerticalTextAlignment="Center" />
                                <Label Text="{Binding SelectedAddress.PostalCode}" FontSize="13" TextColor="#94A3B8" VerticalTextAlignment="Center" />
                            </HorizontalStackLayout>

                            <Label Grid.Row="3" Text="&#x1F30D;" FontSize="14" VerticalTextAlignment="Center" />
                            <Label Grid.Row="3" Grid.Column="1"
                                   Text="{Binding SelectedAddress.Country}" FontSize="13" TextColor="#475569" VerticalTextAlignment="Center" />

                            <Label Grid.Row="4" Text="&#x1F4CD;" FontSize="14" VerticalTextAlignment="Center" />
                            <Label Grid.Row="4" Grid.Column="1"
                                   Text="{Binding CoordsDisplay}" FontSize="12" TextColor="#94A3B8" VerticalTextAlignment="Center" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Tip -->
            <Border StrokeShape="{RoundRectangle CornerRadius=8}"
                    Stroke="#FDE68A" StrokeThickness="1"
                    BackgroundColor="#FFFBEB" Padding="12">
                <HorizontalStackLayout Spacing="8">
                    <Label Text="&#x1F4A1;" FontSize="14" VerticalTextAlignment="Center" />
                    <Label Text="Select a country first to filter address results"
                           FontSize="12" TextColor="#92400E" VerticalTextAlignment="Center" />
                </HorizontalStackLayout>
            </Border>

            <BoxView HeightRequest="20" Color="Transparent" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
