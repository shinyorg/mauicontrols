<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shiny="http://shiny.net/maui/controls"
             xmlns:local="clr-namespace:Sample.Features.ImageEditor"
             x:Class="Sample.Features.ImageEditor.ImageEditorPage"
             x:DataType="local:ImageEditorViewModel"
             Title="Image Editor">

    <shiny:ImageEditor Source="{Binding ImageSource}"
                       CurrentToolMode="{Binding CurrentToolMode}"
                       CanUndo="{Binding CanUndo}"
                       CanRedo="{Binding CanRedo}"
                       DrawStrokeColor="{Binding DrawColor}"
                       DrawStrokeWidth="{Binding DrawStrokeWidth}"
                       AvailableFonts="{Binding AvailableFonts}"
                       TextFontFamily="{Binding TextFontFamily}"
                       SaveCommand="{Binding SaveCommand}"
                       AllowCrop="True"
                       AllowRotate="True"
                       AllowDraw="True"
                       AllowTextAnnotation="True"
                       AllowZoom="True" />

</ContentPage>
