<?xml version="1.0" encoding="utf-8" ?>
<shiny:ShinyContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Sample.Features.Pickers"
             xmlns:shiny="http://shiny.net/maui/controls"
             x:Class="Sample.Features.Pickers.TimePickerPage"
             x:DataType="local:TimePickerViewModel"
             Title="Time Picker">
  <shiny:ShinyContentPage.PageContent>
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Text="ShinyTimePicker"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Label Text="A time picker that opens in a floating panel."
                   FontSize="14"
                   TextColor="Gray" />

            <BoxView HeightRequest="1" Color="LightGray" />

            <Label Text="12-Hour Format" FontSize="16" FontAttributes="Bold" />
            <shiny:ShinyTimePicker Time="{Binding SelectedTime, Mode=TwoWay}"
                                   Placeholder="Choose a time" />

            <Label Text="{Binding SelectedTime, StringFormat='Selected: {0}'}"
                   FontSize="14"
                   TextColor="Gray" />

            <BoxView HeightRequest="1" Color="LightGray" />

            <Label Text="24-Hour Format" FontSize="16" FontAttributes="Bold" />
            <shiny:ShinyTimePicker Time="{Binding MilitaryTime, Mode=TwoWay}"
                                   Use24Hour="True"
                                   Format="HH:mm"
                                   Placeholder="Select time (24h)" />

            <BoxView HeightRequest="1" Color="LightGray" />

            <Label Text="15 Minute Intervals" FontSize="16" FontAttributes="Bold" />
            <shiny:ShinyTimePicker Time="{Binding IntervalTime, Mode=TwoWay}"
                                   MinuteInterval="15"
                                   Placeholder="Pick time (15 min intervals)" />
        </VerticalStackLayout>
    </ScrollView>
  </shiny:ShinyContentPage.PageContent>
</shiny:ShinyContentPage>
