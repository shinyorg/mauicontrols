@using Microsoft.JSInterop
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="shiny-imgeditor" @ref="rootEl">
    <canvas class="shiny-imgeditor-canvas" @ref="canvasEl"></canvas>

    @if (ToolbarTemplate != null)
    {
        <div class="shiny-imgeditor-toolbar">
            @ToolbarTemplate
        </div>
    }
    else
    {
        <div class="shiny-imgeditor-toolbar" style="@(ToolbarPosition == "top" ? "top:0;bottom:auto;" : "")">
            @if (AllowCrop)
            {
                <button class="shiny-imgeditor-btn @(currentMode == "crop" ? "active" : "")"
                        @onclick="ToggleCrop" title="Crop">&#9986;</button>
            }
            @if (AllowRotate)
            {
                <button class="shiny-imgeditor-btn" @onclick="() => RotateAsync(90)" title="Rotate">&#8635;</button>
            }
            @if (AllowDraw)
            {
                <button class="shiny-imgeditor-btn @(currentMode == "draw" ? "active" : "")"
                        @onclick="ToggleDraw" title="Draw">&#9999;</button>
            }
            @if (AllowLine)
            {
                <button class="shiny-imgeditor-btn @(currentMode == "line" ? "active" : "")"
                        @onclick="ToggleLine" title="Line">&#x2500;</button>
            }
            @if (AllowArrow)
            {
                <button class="shiny-imgeditor-btn @(currentMode == "arrow" ? "active" : "")"
                        @onclick="ToggleArrow" title="Arrow">&#x2192;</button>
            }
            @if (AllowTextAnnotation)
            {
                <button class="shiny-imgeditor-btn @(currentMode == "text" ? "active" : "")"
                        @onclick="ToggleText" title="Text">&#x0054;</button>

                @if (currentMode == "text" && AllowFontSelection && AvailableFonts != null)
                {
                    <select class="shiny-imgeditor-select" @onchange="OnFontFamilySelected" title="Font">
                        @foreach (var font in AvailableFonts)
                        {
                            <option value="@font" selected="@(font == TextFontFamily)" style="font-family:@font">@font</option>
                        }
                    </select>
                }
                @if (currentMode == "text" && AllowFontSizeSelection && AvailableFontSizes != null)
                {
                    <select class="shiny-imgeditor-select" @onchange="OnFontSizeSelected" title="Font size">
                        @foreach (var size in AvailableFontSizes)
                        {
                            <option value="@size.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                    selected="@(System.Math.Abs(size - TextFontSize) < 0.001)">@size pt</option>
                        }
                    </select>
                }
            }

            <span class="shiny-imgeditor-separator"></span>

            <button class="shiny-imgeditor-btn" @onclick="async () => await UndoAsync()" disabled="@(!canUndo)" title="Undo">&#8630;</button>
            <button class="shiny-imgeditor-btn" @onclick="async () => await RedoAsync()" disabled="@(!canRedo)" title="Redo">&#8631;</button>
            <button class="shiny-imgeditor-btn" @onclick="async () => await ResetAsync()" title="Reset">&#8634;</button>

            @if (currentMode == "crop")
            {
                <span class="shiny-imgeditor-separator"></span>
                <button class="shiny-imgeditor-btn" @onclick="async () => await ApplyCropAsync()" title="Apply Crop">&#10003;</button>
                <button class="shiny-imgeditor-btn" @onclick="CancelCrop" title="Cancel">&#10007;</button>
            }
        </div>
    }
</div>
