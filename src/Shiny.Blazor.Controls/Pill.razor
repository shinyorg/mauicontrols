@namespace Shiny.Blazor.Controls

<span class="@CssClass" style="@InlineStyle" @attributes="AdditionalAttributes">@Text</span>

@code {
    [Parameter] public string? Text { get; set; }
    [Parameter] public PillType Type { get; set; } = PillType.None;
    [Parameter] public string? PillColor { get; set; }
    [Parameter] public string? PillTextColor { get; set; }
    [Parameter] public string? PillBorderColor { get; set; }
    [Parameter] public double FontSize { get; set; } = 12;
    [Parameter] public double CornerRadius { get; set; } = 12;
    [Parameter] public bool Bold { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? AdditionalAttributes { get; set; }

    string CssClass => $"shiny-pill shiny-pill-{Type.ToString().ToLowerInvariant()}";

    string InlineStyle
    {
        get
        {
            var sb = new System.Text.StringBuilder();
            sb.Append("font-size:").Append(FontSize).Append("px;");
            sb.Append("border-radius:").Append(CornerRadius).Append("px;");
            if (Bold) sb.Append("font-weight:600;");
            if (!string.IsNullOrEmpty(PillColor)) sb.Append("background-color:").Append(PillColor).Append(';');
            if (!string.IsNullOrEmpty(PillTextColor)) sb.Append("color:").Append(PillTextColor).Append(';');
            if (!string.IsNullOrEmpty(PillBorderColor)) sb.Append("border-color:").Append(PillBorderColor).Append(';');
            return sb.ToString();
        }
    }
}
